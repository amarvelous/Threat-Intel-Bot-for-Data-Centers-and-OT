/* ── RADAR CANVAS ───────────────────────────────────────────────── */
function Radar() {
  const ref = useRef();
  const angle = useRef(0);
  const blips = useRef(Array.from({length:6},()=>({ r: Math.random()*.85+.1, a: Math.random()*Math.PI*2, life:1})));

  useEffect(() => {
    const cv = ref.current; if(!cv) return;
    const ctx = cv.getContext("2d");
    let raf;
    const draw = () => {
      const W = cv.width, H = cv.height, cx = W/2, cy = H/2, R = Math.min(W,H)/2 - 4;
      ctx.clearRect(0,0,W,H);
      // rings
      ctx.strokeStyle = "rgba(0,212,255,0.12)";
      ctx.lineWidth = 1;
      [.25,.5,.75,1].forEach(f => { ctx.beginPath(); ctx.arc(cx,cy,R*f,0,Math.PI*2); ctx.stroke(); });
      // crosshairs
      ctx.strokeStyle = "rgba(0,212,255,0.08)";
      [[cx,cy-R,cx,cy+R],[cx-R,cy,cx+R,cy]].forEach(([x1,y1,x2,y2])=>{
        ctx.beginPath(); ctx.moveTo(x1,y1); ctx.lineTo(x2,y2); ctx.stroke();
      });
      // sweep
      angle.current = (angle.current + 0.012) % (Math.PI*2);
      const sweep = ctx.createConicalGradient ? null : null;
      const grad = ctx.createConicGradient ? ctx.createConicGradient(angle.current - 1.2, cx, cy) : null;
      if(grad){
        grad.addColorStop(0,"rgba(0,212,255,0)");
        grad.addColorStop(1,"rgba(0,212,255,0.18)");
        ctx.fillStyle = grad;
        ctx.beginPath(); ctx.arc(cx,cy,R,0,Math.PI*2); ctx.fill();
      }
      // sweep line fallback
      ctx.strokeStyle = "rgba(0,212,255,0.6)";
      ctx.lineWidth = 1.5;
      ctx.beginPath();
      ctx.moveTo(cx,cy);
      ctx.lineTo(cx + Math.cos(angle.current)*R, cy + Math.sin(angle.current)*R);
      ctx.stroke();
      // blips
      blips.current.forEach((b,i) => {
        const da = ((b.a - angle.current) % (Math.PI*2) + Math.PI*2) % (Math.PI*2);
        b.life = da < 0.15 ? 1 : Math.max(0, b.life - 0.008);
        if(b.life < 0.02) blips.current[i] = {r:Math.random()*.8+.1,a:Math.random()*Math.PI*2,life:0};
        const bx = cx + Math.cos(b.a)*R*b.r, by = cy + Math.sin(b.a)*R*b.r;
        ctx.beginPath(); ctx.arc(bx,by,3,0,Math.PI*2);
        ctx.fillStyle = `rgba(255,${b.r>.6?50:200},${b.r>.6?50:100},${b.life})`;
        ctx.fill();
        if(b.life>.5){ ctx.beginPath(); ctx.arc(bx,by,6,0,Math.PI*2); ctx.strokeStyle=`rgba(255,80,80,${b.life*.4})`; ctx.lineWidth=1; ctx.stroke(); }
      });
      raf = requestAnimationFrame(draw);
    };
    draw();
    return () => cancelAnimationFrame(raf);
  },[]);

  return <canvas ref={ref} width={140} height={140} style={{borderRadius:"50%",display:"block"}} />;
}

/* ── MATRIX RAIN (mini) ─────────────────────────────────────────── */
function MatrixStrip() {
  const ref = useRef();
  useEffect(()=>{
    const cv=ref.current; if(!cv) return;
    const ctx=cv.getContext("2d");
    const W=cv.width,H=cv.height,cols=Math.floor(W/10);
    const drops=Array(cols).fill(0);
    let raf;
    const draw=()=>{
      ctx.fillStyle="rgba(2,12,24,0.2)";
      ctx.fillRect(0,0,W,H);
      ctx.fillStyle="rgba(0,212,255,0.5)";
      ctx.font="9px 'Courier New'";
      drops.forEach((y,i)=>{
        const char=String.fromCharCode(0x30A0+Math.random()*96);
        ctx.fillText(char,i*10,y*10);
        if(y*10>H&&Math.random()>0.975) drops[i]=0;
        drops[i]++;
      });
      raf=requestAnimationFrame(draw);
    };
    draw();
    return ()=>cancelAnimationFrame(raf);
  },[]);
  return <canvas ref={ref} width={200} height={60} style={{opacity:.4,display:"block"}} />;
}

