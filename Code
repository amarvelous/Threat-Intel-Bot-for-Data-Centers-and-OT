        <div style={{padding:"10px 14px",borderTop:"1px solid rgba(0,212,255,0.06)"}}>
          <div style={{display:"flex",alignItems:"center",gap:6}}>
            <div style={{width:6,height:6,borderRadius:"50%",background:"#00ff88",boxShadow:"0 0 8px #00ff88",animation:"pulse 2s infinite"}}/>
            <span style={{color:"#1a6a4a",fontSize:9,fontFamily:"'Share Tech Mono',monospace",letterSpacing:2}}>LIVE · {activeSrc.length}/{SOURCES.length} ACTIVE</span>
          </div>
        </div>
      </div>

      {/* ── CENTER MAIN ────────────────────────────────────────── */}
      <div style={{flex:1,display:"flex",flexDirection:"column",minWidth:0}}>

        {/* Top bar */}
        <div style={{padding:"10px 20px",borderBottom:"1px solid rgba(0,212,255,0.08)",background:"rgba(0,4,12,0.9)",backdropFilter:"blur(20px)",display:"flex",alignItems:"center",gap:16,flexShrink:0}}>
          <div style={{flex:1}}>
            <div style={{color:"#60a0b4",fontSize:11,fontFamily:"'Share Tech Mono',monospace",letterSpacing:2,marginBottom:2}}>DATA CENTER & OPERATIONAL TECHNOLOGY</div>
            <div style={{color:"#1a4a5a",fontSize:9,fontFamily:"'Share Tech Mono',monospace",letterSpacing:3}}>SECURITY INTELLIGENCE OPERATIONS CENTER</div>
          </div>
          <div style={{display:"flex",gap:6}}>
            {["DC","OT","API"].map((l,i)=>(
              <div key={l} style={{padding:"4px 10px",background:"rgba(0,212,255,0.06)",border:"1px solid rgba(0,212,255,0.15)",borderRadius:4,color:"#2a7a8a",fontSize:9,fontFamily:"'Share Tech Mono',monospace",letterSpacing:2}}>
                <span style={{color:"#00ff88",marginRight:4}}>●</span>{l}
              </div>
            ))}
          </div>
        </div>

        {/* Ticker */}
        <div style={{padding:"6px 20px",background:"rgba(0,212,255,0.03)",borderBottom:"1px solid rgba(0,212,255,0.06)",display:"flex",alignItems:"center",gap:10,flexShrink:0}}>
          <span style={{color:"#1a4a5a",fontSize:9,fontFamily:"'Share Tech Mono',monospace",letterSpacing:3,flexShrink:0}}>INTEL FEED</span>
          <div style={{width:1,height:12,background:"rgba(0,212,255,0.15)"}}/>
          <Ticker/>
        </div>

        {/* Messages */}
        <div style={{flex:1,overflowY:"auto",padding:"20px 24px 8px"}}>
          {msgs.map((m,i)=><Bubble key={i} msg={m}/>)}
          {loading&&<Typing/>}
          <div ref={bottomRef}/>
        </div>

        {/* Quick Intel */}
        <div style={{padding:"8px 24px 4px",flexShrink:0}}>
          <div style={{display:"flex",gap:6,overflowX:"auto",paddingBottom:4}}>
            {QUICK.map((q,i)=>(
              <button key={i} onClick={()=>send(q.q)} disabled={loading} style={{
                whiteSpace:"nowrap",padding:"5px 12px",
                background:"rgba(0,0,0,0.4)",
                border:"1px solid rgba(0,212,255,0.15)",
                borderRadius:20,color:"#3a7a8a",fontSize:10,
                fontFamily:"'Share Tech Mono',monospace",letterSpacing:1,
                opacity:loading?.5:1,transition:"all .15s",
                cursor:loading?"not-allowed":"pointer"
              }}
              onMouseEnter={e=>{if(!loading){e.target.style.background="rgba(0,212,255,0.08)";e.target.style.color="#00d4ff";e.target.style.borderColor="rgba(0,212,255,0.35)";}}}
              onMouseLeave={e=>{e.target.style.background="rgba(0,0,0,0.4)";e.target.style.color="#3a7a8a";e.target.style.borderColor="rgba(0,212,255,0.15)";}}
              >{q.label}</button>
            ))}
          </div>
        </div>

        {/* Input */}
        <div style={{padding:"8px 24px 20px",flexShrink:0}}>
          <div style={{
            display:"flex",gap:12,alignItems:"flex-end",
            background:"rgba(0,6,18,0.95)",
            border:"1px solid rgba(0,212,255,0.2)",
            borderRadius:10,padding:"10px 14px",
            boxShadow:"0 0 30px rgba(0,212,255,0.05),inset 0 1px 0 rgba(0,212,255,0.04)"
          }}>
            <span style={{color:"#00d4ff",fontFamily:"'Share Tech Mono',monospace",fontSize:13,marginBottom:2,flexShrink:0}}>›_</span>
            <textarea
              ref={taRef} value={input}
              onChange={e=>setInput(e.target.value)}
              onKeyDown={onKey}
              placeholder="Query threat intelligence... CVEs, advisories, TTPs, threat actors, ICS vulnerabilities"
              rows={2} disabled={loading}
              style={{flex:1,background:"transparent",border:"none",color:"#a0c8d8",fontSize:13,lineHeight:1.6,fontFamily:"'Share Tech Mono',monospace"}}
            />
            <button onClick={()=>send()} disabled={loading||!input.trim()} style={{
              width:38,height:38,borderRadius:8,flexShrink:0,
              background:loading||!input.trim()?"rgba(0,212,255,0.05)":"rgba(0,212,255,0.12)",
              border:`1px solid ${loading||!input.trim()?"rgba(0,212,255,0.1)":"rgba(0,212,255,0.4)"}`,
              color:loading||!input.trim()?"#1a4a5a":"#00d4ff",fontSize:16,
              display:"flex",alignItems:"center",justifyContent:"center",
              transition:"all .2s",
              boxShadow:!loading&&input.trim()?"0 0 14px rgba(0,212,255,0.25)":"none"
            }}>
              {loading?"⏳":"⚡"}
            </button>
          </div>
          <div style={{display:"flex",justifyContent:"space-between",marginTop:6,padding:"0 2px"}}>
            <span style={{color:"#0a2a3a",fontSize:9,fontFamily:"'Share Tech Mono',monospace"}}>ENTER TO SEND · SHIFT+ENTER FOR NEWLINE</span>
            <span style={{color:"#0a2a3a",fontSize:9,fontFamily:"'Share Tech Mono',monospace"}}>LIVE WEB SEARCH · ALL SOURCES</span>
          </div>
        </div>
      </div>
    </div>
    </>
  );
}
